---
import { navigationItems } from "../data/navigation";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

---

<header
  class="enterprise-header sticky top-0 z-50 border-b border-border-soft bg-surface-white"
  data-enterprise-header
>
  <div class="section-shell flex h-[3.75rem] items-center gap-6">

    <a href="/" class="shrink-0" aria-label="CNN Legal trang chủ">
      <span class="text-base font-bold tracking-tight text-text-dark">
        CNN Legal
      </span>
    </a>

    <nav
      class="hidden flex-1 items-center gap-0.5 lg:flex"
      aria-label="Điều hướng chính"
    >
      {navigationItems.map((item) => (
        <a
          class:list={[
            "rounded-md px-3 py-2 text-[0.8125rem] font-medium leading-none transition-all hover:bg-surface-subtle hover:shadow-[0_1px_3px_rgba(0,0,0,0.06)]",
            isActive(item.href) ? "text-text-dark" : "text-text-muted hover:text-text-dark",
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex shrink-0 items-center gap-3">
      <a
        href="/lien-he/"
        class="hidden rounded-full bg-ink-black px-4 py-1.5 text-[0.8125rem] font-medium text-white shadow-sm transition-colors hover:bg-ink-hover active:scale-[0.97] lg:inline-flex"
      >
        Liên hệ
      </a>
      <button
        class="inline-flex h-9 w-9 items-center justify-center rounded border border-border-soft text-text-dark hover:border-text-muted hover:bg-surface-subtle lg:hidden"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Mở menu"
        data-menu-button
      >
        <span class="flex w-[1.125rem] flex-col gap-[5px]" aria-hidden="true">
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
        </span>
      </button>
    </div>

  </div>



  <!-- Mobile overlay -->
  <div
    class="fixed inset-0 z-40 hidden bg-ink-black/20 lg:hidden"
    data-nav-overlay
  ></div>

  <!-- Mobile drawer -->
  <aside
    id="mobile-menu"
    class="fixed right-0 top-0 z-50 h-dvh w-[85%] max-w-[360px] translate-x-full overflow-y-auto border-l border-border-soft bg-surface-white px-5 py-5 shadow-[0_0_40px_rgba(15,25,35,0.12)] transition-transform duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] lg:hidden"
    aria-label="Điều hướng di động"
    data-mobile-drawer
  >
    <div class="mb-6 flex items-center justify-between">
      <a href="/" class="text-base font-bold tracking-tight text-text-dark">
        CNN Legal
      </a>
      <button
        class="inline-flex h-8 w-8 items-center justify-center rounded border border-border-soft text-sm text-text-muted hover:border-text-muted hover:bg-surface-subtle"
        type="button"
        aria-label="Đóng menu"
        data-menu-close
      >
        <span aria-hidden="true" class="leading-none">✕</span>
      </button>
    </div>

    <nav class="flex flex-col gap-0.5" aria-label="Điều hướng di động">
      {navigationItems.map((item) => (
        <a
          class:list={[
            "rounded px-3 py-2.5 text-[0.875rem] font-medium hover:bg-surface-subtle hover:text-text-dark",
            isActive(item.href) ? "text-text-dark" : "text-text-muted",
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="mt-6 border-t border-border-soft pt-5">
      <a
        href="/lien-he/"
        class="flex items-center justify-center rounded-full bg-ink-black py-2.5 text-[0.875rem] font-medium text-white transition-all duration-150 ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-ink-hover active:scale-[0.97]"
      >
        Liên hệ
      </a>
    </div>
  </aside>
</header>

<script src="../scripts/navigation.ts"></script>
