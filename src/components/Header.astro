---
import { navigationItems } from "../data/navigation";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
const menuItems = navigationItems.filter((item) => item.groups?.length);
---

<header
  class="enterprise-header sticky top-0 z-50 border-b border-border-soft bg-surface-white"
  data-enterprise-header
>
  <div class="section-shell flex h-[3.75rem] items-center gap-6">

    <a href="/" class="shrink-0" aria-label="CNN Legal trang chủ">
      <span class="text-base font-bold tracking-tight text-text-dark">
        CNN Legal
      </span>
    </a>

    <nav
      class="hidden flex-1 items-center gap-0.5 lg:flex"
      aria-label="Điều hướng chính"
    >
      {navigationItems.map((item) =>
        item.groups?.length ? (
          <button
            class:list={[
              "rounded-md px-3 py-2 text-[0.8125rem] font-medium leading-none transition-all hover:bg-surface-subtle hover:shadow-[0_1px_3px_rgba(0,0,0,0.06)]",
              isActive(item.href) ? "text-text-dark" : "text-text-muted hover:text-text-dark",
            ]}
            type="button"
            aria-expanded="false"
            aria-controls={`mega-${item.id}`}
            data-mega-trigger
          >
            {item.label}
          </button>
        ) : (
          <a
            class:list={[
              "rounded-md px-3 py-2 text-[0.8125rem] font-medium leading-none transition-all hover:bg-surface-subtle hover:shadow-[0_1px_3px_rgba(0,0,0,0.06)]",
              isActive(item.href) ? "text-text-dark" : "text-text-muted hover:text-text-dark",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <div class="ml-auto flex shrink-0 items-center gap-3">
      <a
        href="/lien-he/"
        class="hidden rounded-full bg-ink-black px-4 py-1.5 text-[0.8125rem] font-medium text-white shadow-sm transition-colors hover:bg-ink-hover active:scale-[0.97] lg:inline-flex"
      >
        Liên hệ
      </a>
      <button
        class="inline-flex h-9 w-9 items-center justify-center rounded border border-border-soft text-text-dark hover:border-text-muted hover:bg-surface-subtle lg:hidden"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Mở menu"
        data-menu-button
      >
        <span class="flex w-[1.125rem] flex-col gap-[5px]" aria-hidden="true">
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
        </span>
      </button>
    </div>

  </div>

  <!-- Desktop Mega Panels -->
  <div class="hidden lg:block">
    {menuItems.map((item) => {
      return (
        <div
          id={`mega-${item.id}`}
          class="mega-panel pointer-events-none absolute left-0 right-0 top-full z-40 opacity-0"
          data-mega-panel
        >
          <div class="section-shell pb-3 pt-1">
            <div class="overflow-hidden rounded-xl border border-border-soft bg-surface-white shadow-[0_8px_30px_rgba(15,25,35,0.12)]">
              <div class="flex">
                {/* Left context column */}
                <div class="w-[200px] shrink-0 border-r border-border-soft bg-surface-subtle p-6">
                  <p class="text-[0.8125rem] font-semibold leading-snug text-text-dark">
                    {item.description}
                  </p>
                  <a
                    class="mt-5 inline-flex text-[0.75rem] font-medium text-deep-blue-navy hover:text-professional-blue"
                    href={item.href}
                  >
                    Xem tất cả →
                  </a>
                </div>

                {/* Right content area */}
                <div class="flex-1 p-5">
                  {item.groups?.map((group) => (
                    <div class="mb-4 last:mb-0">
                      <p class="mb-2 text-[0.625rem] font-semibold uppercase tracking-[0.07em] text-text-muted">
                        {group.label}
                      </p>
                      <div class="grid grid-cols-3 gap-x-6 gap-y-0.5">
                        {group.children.map((child) =>
                          child.external ? (
                            <a
                              class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border-soft text-text-muted transition-colors hover:border-deep-blue-navy/40 hover:bg-surface-hover hover:text-deep-blue-navy"
                              href={child.href}
                              rel="noopener noreferrer"
                              target="_blank"
                              title={child.label}
                              aria-label={child.description || child.label}
                            >
                              {child.label === "LinkedIn" && (
                                <svg class="h-4 w-4" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                                  <path d="M12.25 0H1.75C.784 0 0 .784 0 1.75v10.5C0 13.216.784 14 1.75 14h10.5c.966 0 1.75-.784 1.75-1.75V1.75C14 .784 13.216 0 12.25 0zM4.155 11.9H2.1V5.25h2.055v6.65zM3.128 4.375a1.19 1.19 0 110-2.381 1.19 1.19 0 010 2.381zM11.9 11.9H9.845V8.662c0-.772-.014-1.766-1.076-1.766-1.078 0-1.243.841-1.243 1.71v3.294H5.472V5.25h1.973v.908h.027c.275-.52.946-1.068 1.947-1.068 2.082 0 2.466 1.371 2.466 3.153V11.9h.015z"/>
                                </svg>
                              )}
                              {child.label === "dangkimchinh.vn" && (
                                <svg class="h-4 w-4" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                                  <circle cx="7" cy="7" r="6"/>
                                  <path d="M1 7h12M7 1c-1.657 2.333-1.657 4.667 0 6 1.657 1.333 1.657 3.667 0 6M7 1c1.657 2.333 1.657 4.667 0 6-1.657 1.333-1.657 3.667 0 6"/>
                                  <path d="M2 4h10M2 10h10"/>
                                </svg>
                              )}
                            </a>
                          ) : (
                            <a
                              class="group flex items-center gap-2.5 rounded px-2.5 py-2 transition-colors hover:bg-surface-hover"
                              href={child.href}
                            >
                              <div class="min-w-0">
                                <span class="block text-[0.8125rem] font-medium leading-snug text-text-dark">
                                  {child.label}
                                </span>
                                {child.description && (
                                  <span class="mt-0.5 block text-[0.6875rem] leading-4 text-text-muted">
                                    {child.description}
                                  </span>
                                )}
                              </div>
                            </a>
                          )
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Mobile overlay -->
  <div
    class="fixed inset-0 z-40 hidden bg-ink-black/20 lg:hidden"
    data-nav-overlay
  ></div>

  <!-- Mobile drawer -->
  <aside
    id="mobile-menu"
    class="fixed right-0 top-0 z-50 h-dvh w-[85%] max-w-[360px] translate-x-full overflow-y-auto border-l border-border-soft bg-surface-white px-5 py-5 shadow-[0_0_40px_rgba(15,25,35,0.12)] transition-transform duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] lg:hidden"
    aria-label="Điều hướng di động"
    data-mobile-drawer
  >
    <div class="mb-6 flex items-center justify-between">
      <a href="/" class="text-base font-bold tracking-tight text-text-dark">
        CNN Legal
      </a>
      <button
        class="inline-flex h-8 w-8 items-center justify-center rounded border border-border-soft text-sm text-text-muted hover:border-text-muted hover:bg-surface-subtle"
        type="button"
        aria-label="Đóng menu"
        data-menu-close
      >
        <span aria-hidden="true" class="leading-none">✕</span>
      </button>
    </div>

    <nav class="flex flex-col gap-0.5" aria-label="Điều hướng di động">
      {navigationItems.map((item) =>
        item.groups?.length ? (
          <div>
            <button
              class:list={[
                "flex w-full items-center justify-between gap-3 rounded px-3 py-2.5 text-left text-[0.875rem] font-medium hover:bg-surface-subtle",
                isActive(item.href) ? "text-text-dark" : "text-text-muted",
              ]}
              type="button"
              aria-expanded="false"
              aria-controls={`mobile-group-${item.id}`}
              data-accordion-trigger
            >
              <span>{item.label}</span>
            </button>
            <div
              id={`mobile-group-${item.id}`}
              class="accordion-panel"
              data-accordion-panel
            >
              <div class="accordion-inner">
                <div class="py-1 pl-3">
                  {item.groups?.map((group) => (
                    <div class="mb-3 mt-1.5 first:mt-0">
                      <p class="px-2.5 pb-1 text-[0.625rem] font-semibold uppercase tracking-[0.07em] text-text-muted">
                        {group.label}
                      </p>
                      {group.children.map((child) => (
                        <a
                          class="block rounded px-2.5 py-2 text-[0.8125rem] text-text-muted hover:bg-surface-subtle hover:text-text-dark"
                          href={child.href}
                          rel={child.external ? "noopener noreferrer" : undefined}
                          target={child.external ? "_blank" : undefined}
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            class:list={[
              "rounded px-3 py-2.5 text-[0.875rem] font-medium hover:bg-surface-subtle hover:text-text-dark",
              isActive(item.href) ? "text-text-dark" : "text-text-muted",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <div class="mt-6 border-t border-border-soft pt-5">
      <a
        href="/lien-he/"
        class="flex items-center justify-center rounded-full bg-ink-black py-2.5 text-[0.875rem] font-medium text-white transition-all duration-150 ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-ink-hover active:scale-[0.97]"
      >
        Liên hệ
      </a>
    </div>
  </aside>
</header>

<script src="../scripts/navigation.ts"></script>
