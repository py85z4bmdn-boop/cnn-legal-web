---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getAllArticles, type Article } from "../../data/articles";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: Article;
}

const { article } = Astro.props;
const title = `${article.title} | ${site.name}`;
const description = article.excerpt;
const canonicalPath = `/bai-viet/${article.slug}/`;
const pageUrl = new URL(canonicalPath, site.canonicalBaseUrl).toString();
const dateIso = article.publishedAt !== "Đang cập nhật"
  ? article.publishedAt.split("/").reverse().join("-")
  : undefined;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.title,
    description: article.excerpt,
    image: article.imageUrl,
    ...(dateIso ? { datePublished: dateIso } : {}),
    isBasedOn: article.sourceUrl,
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: site.canonicalBaseUrl,
    },
    copyrightHolder: {
      "@type": "Organization",
      name: article.sourceName,
      url: "https://lsvn.vn",
    },
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: site.canonicalBaseUrl },
      { "@type": "ListItem", position: 2, name: "Bài viết", item: new URL("/bai-viet/", site.canonicalBaseUrl).toString() },
      { "@type": "ListItem", position: 3, name: article.title, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={article.imageUrl}
  structuredData={structuredData}
>
  <Breadcrumb items={[{ label: "Trang chủ", href: "/" }, { label: "Bài viết", href: "/bai-viet/" }, { label: article.category }]} />
  <article class="bg-warm-ivory">
    <!-- Page header -->
    <div class="border-b border-border-soft bg-surface-white">
      <div class="section-shell py-10 md:py-12">
        <div class="mt-5 inline-flex items-center gap-2">
          <span class="rounded-sm bg-muted-blue px-2 py-0.5 text-[0.625rem] font-semibold uppercase tracking-[0.06em] text-deep-blue-navy">
            {article.category}
          </span>
          <span class="text-[0.75rem] font-medium text-text-muted">{article.publishedAt}</span>
        </div>

        <h1 class="mt-4 max-w-3xl text-[1.625rem] font-semibold leading-[1.3] text-text-dark md:text-[2rem]">
          {article.title}
        </h1>

        <p class="mt-3 text-[0.875rem] font-medium text-text-muted">
          Nguồn: <span class="text-text-dark">{article.sourceName}</span>
        </p>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="section-shell py-10 md:py-14">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.35fr] lg:items-start">

        <!-- Main content -->
        <div>
          <!-- Article image -->
          <div class="overflow-hidden rounded-sm border border-border-soft bg-text-dark">
            <img
              class="aspect-[16/9] w-full object-cover"
              src={article.imageUrl}
              alt={article.imageAlt}
              loading="eager"
            />
          </div>

          <!-- Source attribution notice -->
          <div class="mt-5 flex items-start gap-3 rounded-sm border border-amber-200 bg-amber-50 p-4">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-600" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 7v4M8 5.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <p class="text-[0.8125rem] leading-6 text-amber-900">
              Bài viết được đăng lại với sự đồng ý của tác giả và{" "}
              <a class="font-medium underline underline-offset-2 hover:text-amber-700" href={article.sourceUrl} rel="noopener noreferrer" target="_blank">
                {article.sourceName}
              </a>.
              Mọi quyền thuộc về tác giả và nguồn gốc.
            </p>
          </div>

          <!-- Full article body -->
          <div class="article-body mt-8 space-y-5">
            {article.bodyParagraphs.map((para) => {
              // Detect if paragraph is a section heading (short, no period at end, often numbered)
              const isHeading = para.length < 120 && !para.endsWith('.') && !para.endsWith(',') && /^(\d+\.|[IVX]+\.|[A-Z])/.test(para);
              return isHeading ? (
                <h2 class="pt-3 text-[1.0625rem] font-semibold leading-snug text-text-dark first:pt-0">
                  {para}
                </h2>
              ) : (
                <p class="text-[0.9375rem] leading-[1.8] text-text-dark">
                  {para}
                </p>
              );
            })}
          </div>

          <!-- Source footer -->
          <div class="mt-10 border-t border-border-soft pt-6">
            <p class="text-[0.8125rem] font-semibold text-text-muted">
              Nguồn: {article.sourceName}
            </p>
            <a
              class="mt-2 inline-flex items-center gap-1.5 text-[0.8125rem] font-medium text-deep-blue-navy hover:text-professional-blue"
              href={article.sourceUrl}
              rel="noopener noreferrer"
              target="_blank"
            >
              {article.originalLinkLabel}
              <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <div class="mt-6 lg:hidden">
            <a class="secondary-button" href="/bai-viet/">← Tất cả bài viết</a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-20 space-y-4">
          <div class="rounded-sm border border-border-soft bg-surface-white">
            <div class="border-b border-border-soft p-5">
              <p class="text-[0.625rem] font-semibold uppercase tracking-[0.06em] text-text-muted">Nguồn bài viết</p>
              <p class="mt-2 text-[0.875rem] font-semibold leading-snug text-text-dark">{article.sourceName}</p>
            </div>
            <dl class="divide-y divide-border-soft text-[0.8125rem]">
              <div class="px-5 py-3.5">
                <dt class="font-medium text-text-muted">Ngày đăng</dt>
                <dd class="mt-1 font-semibold text-text-dark">{article.publishedAt}</dd>
              </div>
              <div class="px-5 py-3.5">
                <dt class="font-medium text-text-muted">Chuyên mục</dt>
                <dd class="mt-1 font-semibold text-text-dark">{article.category}</dd>
              </div>
            </dl>
            <div class="p-5 space-y-2.5">
              <a
                class="primary-button w-full"
                href={article.sourceUrl}
                rel="noopener noreferrer"
                target="_blank"
              >
                {article.originalLinkLabel}
              </a>
              <a class="secondary-button w-full hidden lg:inline-flex" href="/bai-viet/">
                ← Tất cả bài viết
              </a>
            </div>
          </div>

          <div class="rounded-sm border border-border-soft bg-surface-subtle p-5">
            <p class="text-[0.8125rem] font-semibold text-text-dark">Cần tư vấn pháp lý?</p>
            <p class="mt-2 text-[0.75rem] leading-5 text-text-muted">
              CNN Legal hỗ trợ đánh giá bước đầu qua email và điện thoại.
            </p>
            <a class="mt-3 inline-flex text-[0.8125rem] font-medium text-deep-blue-navy hover:text-professional-blue" href="/lien-he/">
              Thông tin liên hệ →
            </a>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
