---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/services";
import { site } from "../../data/site";

const title = `Dịch vụ pháp lý | ${site.name}`;
const description =
  "Các dịch vụ pháp lý của CNN Legal được trình bày theo từng lĩnh vực để khách hàng dễ xác định nhu cầu tư vấn ban đầu.";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: new URL("/dich-vu/", site.canonicalBaseUrl).toString(),
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Trang chủ",
        item: site.canonicalBaseUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Dịch vụ",
        item: new URL("/dich-vu/", site.canonicalBaseUrl).toString(),
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath="/dich-vu/" structuredData={structuredData}>
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-b from-ink-black via-[#142a45] to-deep-blue-navy">
      <div class="section-shell py-20 md:py-28 lg:py-32">
        <nav class="text-[0.8125rem] font-medium text-white/35" aria-label="Breadcrumb">
          <a class="transition-colors hover:text-white/60" href="/">Trang chủ</a>
          <svg class="mx-1.5 inline-block h-3 w-3 text-white/25" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M4.5 2.5L7.5 6L4.5 9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-white/50">Dịch vụ</span>
        </nav>

        <h1 class="mt-8 max-w-3xl text-[2.25rem] font-semibold leading-[1.14] tracking-[-0.01em] text-white md:text-[2.75rem] lg:text-[3.125rem]">
          Lĩnh vực hỗ trợ của CNN Legal
        </h1>

        <p class="mt-6 max-w-xl text-[1rem] leading-[1.8] text-white/65 md:text-[1.0625rem]">
          Mỗi lĩnh vực cần được xem xét dựa trên hồ sơ cụ thể. Các trang dưới đây giúp khách hàng hiểu phạm vi hỗ trợ trước khi liên hệ tư vấn.
        </p>
      </div>
    </div>

    <div class="relative h-[180px] md:h-[220px]">
      <img
        class="absolute inset-0 h-full w-full object-cover"
        src="/images/services-section.png"
        alt=""
        loading="eager"
      />
      <div class="absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-deep-blue-navy to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-warm-ivory to-transparent"></div>
    </div>
  </section>

  <section class="bg-warm-ivory">
    <div class="section-shell pb-16 pt-10 md:pb-20 md:pt-12">
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => (
          <a class="group rounded-lg border border-border-soft bg-surface-white p-7 transition-colors hover:border-deep-blue-navy/25 hover:bg-muted-blue/50" href={`/dich-vu/${service.slug}/`}>
            <h2 class="text-[1.125rem] font-semibold leading-snug text-text-dark group-hover:text-deep-blue-navy">{service.title}</h2>
            <p class="mt-3.5 text-[0.875rem] leading-[1.75] text-text-muted">{service.summary}</p>
            <span class="mt-5 inline-block text-[0.8125rem] font-semibold text-deep-blue-navy">Đọc thêm →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
