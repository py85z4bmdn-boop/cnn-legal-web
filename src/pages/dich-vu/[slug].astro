---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { services, type Service } from "../../data/services";
import { site } from "../../data/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const title = `${service.title} | ${site.name}`;
const description = service.summary;
const canonicalPath = `/dich-vu/${service.slug}/`;
const serviceUrl = new URL(canonicalPath, site.canonicalBaseUrl).toString();
const relatedServices = services.filter((item) => item.slug !== service.slug).slice(0, 3);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.title,
    description: service.summary,
    url: serviceUrl,
    provider: {
      "@type": "LegalService",
      name: site.name,
      url: site.canonicalBaseUrl,
      ...(site.publicPhone ? { telephone: site.publicPhone } : {}),
    },
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Trang chủ",
        item: site.canonicalBaseUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Dịch vụ",
        item: new URL("/dich-vu/", site.canonicalBaseUrl).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: service.title,
        item: serviceUrl,
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <Breadcrumb items={[{ label: "Trang chủ", href: "/" }, { label: "Dịch vụ", href: "/dich-vu/" }, { label: service.title }]} />
  <section class="bg-warm-ivory">
    <div class="section-shell py-16 md:py-20">

      <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_0.42fr] lg:items-start">
        <article>
          <h1 class="text-4xl font-bold leading-tight text-text-dark md:text-5xl">
            {service.title}
          </h1>
          <p class="mt-6 text-lg leading-8 text-text-muted">{service.description}</p>

          <div class="mt-10 grid gap-5">
            <section class="rounded-xl border border-border-soft bg-surface-white p-6 md:p-8" aria-labelledby="service-definition">
              <h2 id="service-definition" class="text-2xl font-bold text-text-dark">Dịch vụ này là gì</h2>
              <p class="mt-5 text-base leading-8 text-text-muted">{service.description}</p>
            </section>

            <section class="rounded-xl border border-border-soft bg-surface-white p-6 md:p-8" aria-labelledby="situations">
              <h2 id="situations" class="text-2xl font-bold text-text-dark">Khi nào khách hàng có thể cần</h2>
              <ul class="mt-6 grid gap-4">
                {service.situations.map((item) => (
                  <li class="flex gap-3 text-base leading-8 text-text-muted">
                    <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-warm-orange" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>

            <section class="rounded-xl border border-border-soft bg-surface-white p-6 md:p-8" aria-labelledby="approach">
              <h2 id="approach" class="text-2xl font-bold text-text-dark">CNN Legal tiếp cận vấn đề như thế nào</h2>
              <ul class="mt-6 grid gap-4">
                {service.approach.map((item) => (
                  <li class="flex gap-3 text-base leading-8 text-text-muted">
                    <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-professional-blue" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>

            <section class="rounded-xl border border-border-soft bg-surface-white p-6 md:p-8" aria-labelledby="scope">
              <h2 id="scope" class="text-2xl font-bold text-text-dark">Phạm vi hỗ trợ</h2>
              <ul class="mt-6 grid gap-4">
                {service.points.map((point) => (
                  <li class="flex gap-3 text-base leading-8 text-text-muted">
                    <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-deep-blue-navy" aria-hidden="true"></span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </section>
          </div>

          <div class="mt-8 rounded-lg border border-border-soft bg-muted-blue p-5 text-sm leading-7 text-text-muted">
            Nội dung trên trang này giúp định hướng ban đầu. Việc tư vấn cụ thể cần dựa trên tài liệu, mốc thời gian và mục tiêu xử lý của khách hàng.
          </div>
        </article>

        <aside class="rounded-xl border border-border-soft bg-surface-white p-6">
          <h2 class="text-lg font-bold text-text-dark">Trao đổi về dịch vụ này</h2>
          <p class="mt-3 text-sm leading-7 text-text-muted">
            Cần kiểm tra hồ sơ hoặc rủi ro pháp lý? Liên hệ trực tiếp để trao đổi bước đầu.
          </p>
          <a class="primary-button mt-6 w-full" href="/lien-he/">Liên hệ tư vấn</a>
        </aside>
      </div>

      <section class="mt-14" aria-labelledby="related-services">
        <h2 id="related-services" class="text-2xl font-bold text-text-dark">Dịch vụ liên quan</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {relatedServices.map((item) => (
            <a class="rounded-lg border border-border-soft bg-surface-white p-5 hover:border-professional-blue hover:bg-muted-blue/60" href={`/dich-vu/${item.slug}/`}>
              <h3 class="font-bold leading-snug text-text-dark">{item.title}</h3>
              <p class="mt-3 text-sm leading-6 text-text-muted">{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
