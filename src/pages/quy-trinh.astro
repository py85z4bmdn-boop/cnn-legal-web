---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { processSteps, site } from "../data/site";

const title = `Quy trình làm việc | ${site.name}`;
const description =
  "Quy trình làm việc của CNN Legal giúp khách hàng hiểu cách tiếp nhận thông tin, đánh giá pháp lý, đề xuất hướng xử lý và đồng hành thực hiện.";
const pagePath = "/quy-trinh/";
const pageUrl = new URL(pagePath, site.canonicalBaseUrl).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: pageUrl,
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: site.canonicalBaseUrl },
      { "@type": "ListItem", position: 2, name: "Quy trình", item: pageUrl },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={pagePath} structuredData={structuredData} noindex>
  <Breadcrumb items={[{ label: "Trang chủ", href: "/" }, { label: "Quy trình" }]} />
  <section class="bg-warm-ivory">
    <div class="section-shell py-16 md:py-20">

      <div class="mt-8 max-w-3xl">
        <p class="section-kicker">Quy trình làm việc</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-text-dark md:text-5xl">
          Làm rõ vấn đề trước khi chọn hướng xử lý.
        </h1>
        <p class="mt-5 text-base leading-8 text-text-muted">
          Một vụ việc pháp lý cần được nhìn theo hồ sơ, mốc thời gian và mục tiêu thực tế. Quy trình dưới đây giúp khách hàng biết điều gì sẽ được làm ở từng bước.
        </p>
      </div>

      <div class="mt-10 grid gap-5">
        {processSteps.map((step, index) => (
          <article id={step.id} class="scroll-mt-28 grid gap-4 rounded-xl border border-border-soft bg-surface-white p-6 md:grid-cols-[8rem_1fr] md:p-8">
            <div>
              <p class="text-sm font-bold text-warm-orange">0{index + 1}</p>
              <h2 class="mt-2 text-xl font-bold text-text-dark">{step.title}</h2>
            </div>
            <p class="text-base leading-8 text-text-muted">{step.detail}</p>
          </article>
        ))}
      </div>

      <a class="primary-button mt-10" href="/lien-he/">Liên hệ tư vấn</a>
    </div>
  </section>
</BaseLayout>
