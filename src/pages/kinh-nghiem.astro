---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { experienceItems } from "../data/experience";
import { site } from "../data/site";

const title = `Kinh nghiệm xử lý | ${site.name}`;
const description =
  "Các nhóm vấn đề CNN Legal có thể hỗ trợ được trình bày an toàn, không công bố chi tiết vụ việc nhạy cảm và không hứa hẹn kết quả.";
const pagePath = "/kinh-nghiem/";
const pageUrl = new URL(pagePath, site.canonicalBaseUrl).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: pageUrl,
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: site.canonicalBaseUrl },
      { "@type": "ListItem", position: 2, name: "Kinh nghiệm", item: pageUrl },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={pagePath} structuredData={structuredData}>
  <Breadcrumb items={[{ label: "Trang chủ", href: "/" }, { label: "Kinh nghiệm" }]} />
  <section class="bg-warm-ivory">
    <div class="section-shell py-16 md:py-20">

      <div class="mt-8 max-w-3xl">
        <p class="section-kicker">Kinh nghiệm xử lý</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-text-dark md:text-5xl">
          Nhóm vấn đề thường cần được đánh giá kỹ.
        </h1>
        <p class="mt-5 text-base leading-8 text-text-muted">
          CNN Legal không công bố chi tiết vụ việc nhạy cảm, không nêu các chiến thắng bí mật và không dùng kết quả quá khứ để hứa hẹn kết quả tương lai.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {experienceItems.map((item) => (
          <article id={item.id} class="scroll-mt-28 rounded-lg border border-border-soft bg-surface-white p-6">
            <h2 class="text-xl font-bold text-text-dark">{item.title}</h2>
            <p class="mt-4 text-sm leading-7 text-text-muted">{item.summary}</p>
          </article>
        ))}
      </div>

      <a class="primary-button mt-10" href="/lien-he/">Liên hệ tư vấn</a>
    </div>
  </section>
</BaseLayout>
