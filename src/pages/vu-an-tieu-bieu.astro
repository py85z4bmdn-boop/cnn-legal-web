---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { notableCases } from "../data/cases";
import { site } from "../data/site";

const title = `Vụ án tiêu biểu | ${site.name}`;
const description =
  "Các vụ án tiêu biểu mà Luật sư Đặng Kim Chinh đã tham gia bào chữa tại TAND Cấp cao tại TP.HCM, bao gồm đại án Vạn Thịnh Phát và vụ buôn lậu xăng dầu quy mô lớn.";
const canonicalPath = "/vu-an-tieu-bieu/";
const pageUrl = new URL(canonicalPath, site.canonicalBaseUrl).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: pageUrl,
    inLanguage: "vi-VN",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: site.canonicalBaseUrl },
      { "@type": "ListItem", position: 2, name: "Vụ án tiêu biểu", item: pageUrl },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <Breadcrumb items={[{ label: "Trang chủ", href: "/" }, { label: "Vụ án tiêu biểu" }]} />

  <!-- Page header -->
  <div class="border-b border-border-soft bg-surface-white">
    <div class="section-shell py-12 md:py-16">
      <div class="max-w-2xl">
        <h1 class="text-3xl font-semibold leading-tight text-text-dark md:text-4xl">
          Vụ án tiêu biểu.
        </h1>
        <p class="mt-4 text-[0.9375rem] leading-7 text-text-muted">
          Luật sư Đặng Kim Chinh đã tham gia bào chữa trong nhiều vụ án hình sự lớn tại Việt Nam.
          Dưới đây là danh sách các vụ án tiêu biểu, kèm nguồn dẫn từ báo chí uy tín.
        </p>
      </div>
    </div>
  </div>

  <!-- Cases list -->
  <div class="bg-warm-ivory">
    <div class="section-shell py-12 md:py-16">
      <div class="space-y-8">
        {notableCases.map((caseItem, index) => (
          <article
            class="overflow-hidden rounded-xl border border-border-soft bg-surface-white shadow-[0_2px_12px_rgba(15,25,35,0.04)] transition-shadow hover:shadow-[0_4px_20px_rgba(15,25,35,0.08)]"
            id={caseItem.id}
          >
            <div class="p-6 md:p-8 lg:p-10">
              <!-- Header -->
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center rounded-full bg-deep-blue-navy px-2.5 py-0.5 text-[0.6875rem] font-semibold text-white">
                      {caseItem.year}
                    </span>
                    <span class="text-[0.75rem] font-medium text-text-muted">
                      {caseItem.court}
                    </span>
                  </div>
                  <h2 class="mt-3 text-[1.25rem] font-bold leading-snug text-text-dark md:text-[1.375rem]">
                    {caseItem.title}
                  </h2>
                </div>
                <span class="shrink-0 rounded-md border border-border-soft bg-surface-subtle px-3 py-1 text-[0.75rem] font-medium text-text-muted">
                  #{String(index + 1).padStart(2, "0")}
                </span>
              </div>

              <!-- Meta grid -->
              <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                  <p class="text-[0.625rem] font-semibold uppercase tracking-[0.08em] text-text-muted">Vai trò</p>
                  <p class="mt-1 text-[0.8125rem] font-medium text-text-dark">{caseItem.role}</p>
                </div>
                <div>
                  <p class="text-[0.625rem] font-semibold uppercase tracking-[0.08em] text-text-muted">Bị cáo</p>
                  <p class="mt-1 text-[0.8125rem] font-medium text-text-dark">{caseItem.defendant}</p>
                </div>
                <div>
                  <p class="text-[0.625rem] font-semibold uppercase tracking-[0.08em] text-text-muted">Tội danh</p>
                  <p class="mt-1 text-[0.8125rem] font-medium text-text-dark">{caseItem.charge}</p>
                </div>
                <div>
                  <p class="text-[0.625rem] font-semibold uppercase tracking-[0.08em] text-text-muted">Thời gian</p>
                  <p class="mt-1 text-[0.8125rem] font-medium text-text-dark">{caseItem.date}</p>
                </div>
              </div>

              <!-- Summary -->
              <div class="mt-6 rounded-lg bg-surface-subtle p-5">
                <p class="text-[0.8125rem] leading-[1.75] text-text-muted">
                  {caseItem.summary}
                </p>
              </div>

              <!-- Key arguments -->
              {caseItem.keyArguments.length > 0 && (
                <div class="mt-6">
                  <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-text-muted">
                    Luận điểm bào chữa chính
                  </p>
                  <ul class="mt-3 space-y-2.5">
                    {caseItem.keyArguments.map((arg) => (
                      <li class="flex gap-3 text-[0.8125rem] leading-[1.7] text-text-muted">
                        <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-deep-blue-navy" aria-hidden="true"></span>
                        <span>{arg}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <!-- Result -->
              {caseItem.result && (
                <div class="mt-6 flex items-center gap-3 rounded-lg border border-green-100 bg-green-50 px-5 py-3">
                  <svg class="h-5 w-5 shrink-0 text-green-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                  </svg>
                  <div>
                    <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.06em] text-green-700">Kết quả</p>
                    <p class="text-[0.8125rem] font-medium text-green-800">{caseItem.result}</p>
                  </div>
                </div>
              )}

              <!-- Sources -->
              <div class="mt-6 border-t border-border-soft pt-5">
                <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-text-muted">
                  Nguồn tham khảo
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {caseItem.sources.map((source, srcIndex) => (
                    <a
                      class="inline-flex items-center gap-1.5 rounded-md border border-border-soft bg-surface-white px-3 py-1.5 text-[0.75rem] font-medium text-deep-blue-navy shadow-sm transition-all hover:border-deep-blue-navy/30 hover:shadow-md"
                      href={source.url}
                      rel="noopener noreferrer"
                      target="_blank"
                    >
                      <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M6.5 3.5H3a1 1 0 00-1 1v8a1 1 0 001 1h8a1 1 0 001-1V9.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9.5 2h4.5v4.5M14 2L7 9" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <span>{source.name}</span>
                      {caseItem.sources.length > 1 && (
                        <span class="text-text-muted">({srcIndex + 1})</span>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Disclaimer -->
      <div class="mt-12 rounded-lg border border-border-soft bg-surface-white p-6 text-center">
        <p class="text-[0.8125rem] leading-[1.7] text-text-muted">
          Các thông tin trên được tổng hợp từ nguồn báo chí công khai tại Việt Nam.
          <br class="hidden sm:inline" />
          CNN Legal không đại diện cho quan điểm của bất kỳ cơ quan tư pháp nào.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
